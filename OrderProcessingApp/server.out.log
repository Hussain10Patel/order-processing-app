                  DO $$
                  BEGIN
                      IF NOT EXISTS (
                          SELECT 1
                          FROM pg_indexes
                          WHERE schemaname = 'public'
                            AND indexname = 'IX_Products_SKUCode_Normalized')
                      THEN
