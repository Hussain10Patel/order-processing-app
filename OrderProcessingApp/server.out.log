                  UPDATE "Orders"
                  SET "TotalPallets" = COALESCE(order_totals."TotalPallets", 0)
                  FROM (
                      SELECT "OrderId", SUM("Pallets") AS "TotalPallets"
                      FROM "OrderItems"
                      GROUP BY "OrderId"
                  ) AS order_totals
                  WHERE order_totals."OrderId" = "Orders"."Id";
      
                  UPDATE "Orders"
                  SET "TotalPallets" = 0
                  WHERE "Id" NOT IN (SELECT DISTINCT "OrderId" FROM "OrderItems");
